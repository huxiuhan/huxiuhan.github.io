---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found | Hu Xiuhan" description="The page you are looking for could not be found.">
  <main class="not-found">
    <div class="wrapper not-found-inner">
      <p class="section-label">404</p>
      <h1>Page not found</h1>
      <p>
        The page you were looking for has either moved or never existed in the first place.
      </p>
      <p>
        <a href="/">Return home</a>
      </p>
    </div>
  </main>
</BaseLayout>
